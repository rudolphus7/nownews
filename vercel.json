{
    "cleanUrls": true,
    "trailingSlash": true,
    "redirects": [
        {
            "source": "/api/:path*",
            "destination": "/api/:path*",
            "permanent": false
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "city"
                }
            ],
            "destination": "/:city/",
            "permanent": true
        },
        {
            "source": "/index.html",
            "has": [
                {
                    "type": "query",
                    "key": "city",
                    "value": "(?<city>.+)"
                }
            ],
            "destination": "/:city/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "war"
                }
            ],
            "destination": "/category/viyna/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "politics"
                }
            ],
            "destination": "/category/polityka/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "economy"
                }
            ],
            "destination": "/category/ekonomika/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "sport"
                }
            ],
            "destination": "/category/sport/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "culture"
                }
            ],
            "destination": "/category/kultura/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "tech"
                }
            ],
            "destination": "/category/tekhnolohii/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "frankivsk"
                }
            ],
            "destination": "/category/frankivsk/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "oblast"
                }
            ],
            "destination": "/category/oblast/",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/api/:handler/",
            "destination": "/api/index?__target=:handler"
        },
        {
            "source": "/api/:handler",
            "destination": "/api/index?__target=:handler"
        },
        {
            "source": "/category/:cat/:slug/",
            "destination": "/api/index?__target=news&slug=:slug"
        },
        {
            "source": "/:city/:slug/",
            "destination": "/api/index?__target=news&slug=:slug"
        },
        {
            "source": "/sitemap.xml",
            "destination": "/api/index?__target=sitemap"
        },
        {
            "source": "/sitemap-pages.xml",
            "destination": "/api/index?__target=sitemap&type=pages"
        },
        {
            "source": "/sitemap-posts.xml",
            "destination": "/api/index?__target=sitemap&type=posts"
        },
        {
            "source": "/sitemap-news.xml",
            "destination": "/api/index?__target=sitemap&type=news"
        },
        {
            "source": "/news/:slug/",
            "destination": "/api/index?__target=news&slug=:slug"
        },
        {
            "source": "/news/",
            "has": [
                {
                    "type": "query",
                    "key": "slug"
                }
            ],
            "destination": "/api/index?__target=news"
        },
        {
            "source": "/news/",
            "has": [
                {
                    "type": "query",
                    "key": "id"
                }
            ],
            "destination": "/api/index?__target=news"
        },
        {
            "source": "/category/:slug/",
            "destination": "/api/index?__target=category&slug=:slug"
        },
        {
            "source": "/:city(kalush|if|kolomyya|dolyna|bolekhiv|nadvirna|burshtyn|kosiv|yaremche)/",
            "destination": "/api/index?__target=city&city=:city"
        },
        {
            "source": "/live/",
            "destination": "/api/index?__target=live"
        },
        {
            "source": "/news/",
            "destination": "/index.html"
        },
        {
            "source": "/feed/",
            "destination": "/api/index?__target=rss"
        },
        {
            "source": "/rss/",
            "destination": "/api/index?__target=rss"
        },
        {
            "source": "/:slug/",
            "destination": "/api/index?__target=news&slug=:slug"
        }
    ],
    "headers": [
        {
            "source": "/components/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*)\\.(ico|png|jpg|jpeg|svg|css|js)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "functions": {
        "api/index.js": {
            "memory": 1024,
            "maxDuration": 60
        }
    }
}