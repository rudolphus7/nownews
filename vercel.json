{
    "cleanUrls": true,
    "trailingSlash": true,
    "redirects": [
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "city"
                }
            ],
            "destination": "/:city/",
            "permanent": true
        },
        {
            "source": "/index.html",
            "has": [
                {
                    "type": "query",
                    "key": "city",
                    "value": "(?<city>.+)"
                }
            ],
            "destination": "/:city/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "war"
                }
            ],
            "destination": "/category/viyna/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "politics"
                }
            ],
            "destination": "/category/polityka/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "economy"
                }
            ],
            "destination": "/category/ekonomika/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "sport"
                }
            ],
            "destination": "/category/sport/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "culture"
                }
            ],
            "destination": "/category/kultura/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "tech"
                }
            ],
            "destination": "/category/tekhnolohii/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "frankivsk"
                }
            ],
            "destination": "/category/frankivsk/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "oblast"
                }
            ],
            "destination": "/category/oblast/",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/category/:cat/:slug/",
            "destination": "/api/news?slug=:slug"
        },
        {
            "source": "/:city/:slug/",
            "destination": "/api/news?slug=:slug"
        },
        {
            "source": "/sitemap.xml",
            "destination": "/api/sitemap"
        },
        {
            "source": "/sitemap-pages.xml",
            "destination": "/api/sitemap?type=pages"
        },
        {
            "source": "/sitemap-posts.xml",
            "destination": "/api/sitemap?type=posts"
        },
        {
            "source": "/sitemap-news.xml",
            "destination": "/api/sitemap?type=news"
        },
        {
            "source": "/news/:slug/",
            "destination": "/api/news?slug=:slug"
        },
        {
            "source": "/news/",
            "has": [
                {
                    "type": "query",
                    "key": "slug"
                }
            ],
            "destination": "/api/news"
        },
        {
            "source": "/news/",
            "has": [
                {
                    "type": "query",
                    "key": "id"
                }
            ],
            "destination": "/api/news"
        },
        {
            "source": "/category/:slug/",
            "destination": "/api/category?slug=:slug"
        },
        {
            "source": "/:city(kalush|if|kolomyya|dolyna|bolekhiv|nadvirna|burshtyn|kosiv|yaremche)/",
            "destination": "/api/city?city=:city"
        },
        {
            "source": "/live/",
            "destination": "/api/live"
        },
        {
            "source": "/news/",
            "destination": "/index.html"
        },
        {
            "source": "/:slug/",
            "destination": "/api/news?slug=:slug"
        }
    ],
    "functions": {
        "api/admin-auth.js": {
            "memory": 128,
            "maxDuration": 10
        },
        "api/city.js": {
            "memory": 128,
            "maxDuration": 10
        },
        "api/category.js": {
            "maxDuration": 10,
            "memory": 128
        },
        "api/sitemap.js": {
            "maxDuration": 60,
            "memory": 1024
        },
        "api/tts.js": {
            "memory": 256,
            "maxDuration": 60
        },
        "api/subscribe.js": {
            "memory": 128,
            "maxDuration": 10
        },
        "api/ai.js": {
            "memory": 256,
            "maxDuration": 30
        }
    }
}