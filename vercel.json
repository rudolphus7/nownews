{
    "cleanUrls": true,
    "trailingSlash": true,
    "redirects": [
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "city"
                }
            ],
            "destination": "/:city/",
            "permanent": true
        },
        {
            "source": "/index.html",
            "has": [
                {
                    "type": "query",
                    "key": "city",
                    "value": "(?<city>.+)"
                }
            ],
            "destination": "/:city/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "war"
                }
            ],
            "destination": "/category/viyna/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "politics"
                }
            ],
            "destination": "/category/polityka/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "economy"
                }
            ],
            "destination": "/category/ekonomika/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "sport"
                }
            ],
            "destination": "/category/sport/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "culture"
                }
            ],
            "destination": "/category/kultura/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "tech"
                }
            ],
            "destination": "/category/tekhnolohii/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "frankivsk"
                }
            ],
            "destination": "/category/frankivsk/",
            "permanent": true
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "category",
                    "value": "oblast"
                }
            ],
            "destination": "/category/oblast/",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/category/:cat(viyna|polityka|ekonomika|sport|kultura|tekhnolohii|frankivsk|oblast)/:slug/",
            "destination": "/api/news?slug=:slug"
        },
        {
            "source": "/:city(kalush|if|kolomyya|dolyna|bolekhiv|nadvirna|burshtyn|kosiv|yaremche)/:slug/",
            "destination": "/api/news?slug=:slug"
        },
        {
            "source": "/sitemap.xml",
            "destination": "/api/sitemap.xml"
        },
        {
            "source": "/sitemap-news.xml",
            "destination": "/api/sitemap-news.xml"
        },
        {
            "source": "/news/:slug/",
            "destination": "/api/news?slug=:slug"
        },
        {
            "source": "/news/",
            "has": [
                {
                    "type": "query",
                    "key": "slug"
                }
            ],
            "destination": "/api/news"
        },
        {
            "source": "/news/",
            "has": [
                {
                    "type": "query",
                    "key": "id"
                }
            ],
            "destination": "/api/news"
        },
        {
            "source": "/category/:slug/",
            "destination": "/api/category?slug=:slug"
        },
        {
            "source": "/:city(kalush|if|kolomyya|dolyna|bolekhiv|nadvirna|burshtyn|kosiv|yaremche)/",
            "destination": "/api/city?city=:city"
        },
        {
            "source": "/live/",
            "destination": "/live.html"
        },
        {
            "source": "/news/",
            "destination": "/index.html"
        }
    ],
    "functions": {
        "api/admin-auth.js": {
            "memory": 128,
            "maxDuration": 10
        },
        "api/city.js": {
            "memory": 128,
            "maxDuration": 10
        },
        "api/category.js": {
            "memory": 128,
            "maxDuration": 10
        },
        "api/sitemap.xml.js": {
            "memory": 128,
            "maxDuration": 30
        },
        "api/sitemap-news.xml.js": {
            "memory": 128,
            "maxDuration": 15
        },
        "api/tts.js": {
            "memory": 256,
            "maxDuration": 60
        }
    }
}