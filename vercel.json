{
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
            "source": "/news/:slug",
            "destination": "/api/news?slug=:slug"
        },
        {
            "source": "/news",
            "has": [
                {
                    "type": "query",
                    "key": "slug"
                }
            ],
            "destination": "/api/news"
        },
        {
            "source": "/news",
            "has": [
                {
                    "type": "query",
                    "key": "id"
                }
            ],
            "destination": "/api/news"
        },
        {
            "source": "/news",
            "destination": "/index.html"
        }
    ],
    "functions": {
        "api/admin-auth.js": {
            "memory": 128,
            "maxDuration": 10
        }
    }
}